{
    "name": "gosuperscript/axiom",
    "description": "PHP reference implementation workspace for the Axiom DSL.",
    "type": "library",
    "license": "MIT",
    "keywords": ["php", "axiom", "dsl", "rules", "pricing"],
    "require": {
        "php": "^8.4",
        "ext-intl": "*",
        "brick/math": "^0.12.0 || ^0.13.0"
    },
    "require-dev": {
        "laravel/pint": "^1.22",
        "phpstan/phpstan": "2.1.45",
        "phpunit/phpunit": "12.5.11"
    },
    "autoload": {
        "psr-4": {
            "Superscript\\Axiom\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Superscript\\Axiom\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test:types": "vendor/bin/phpstan analyse --configuration phpstan.neon.dist",
        "test:unit": "vendor/bin/phpunit --configuration phpunit.xml.dist",
        "format": "vendor/bin/pint",
        "test": [
            "@test:types",
            "@test:unit"
        ]
    },
    "config": {
        "sort-packages": true,
        "platform": {
            "php": "8.4.0"
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
