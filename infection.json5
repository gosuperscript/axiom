{
  "$schema": "vendor/infection/infection/resources/schema.json",
  "source": {
    "directories": [
      "src"
    ],
    "excludes": [
      "Testing"
    ]
  },
  "timeout": 10,
  "minCoveredMsi": 100,
  "minMsi": 100,
  "mutators": {
    "@default": true,

    // ── Globally disabled ────────────────────────────────────────────
    //
    // PublicVisibility: tests coupling, not logic. The public API is
    // defined by interfaces; flipping public→protected never catches bugs.
    "PublicVisibility": false,
    // Concat / ConcatOperandRemoval: almost exclusively hits error
    // messages and debug strings — mutating text doesn't test correctness.
    "Concat": false,
    "ConcatOperandRemoval": false,
    // Logical*Negation / *SubExpr variants: combinatorial expansions of
    // LogicalAnd and LogicalOr. The base mutators already catch real
    // logic errors; these add ~175 mutants that never find anything extra.
    "LogicalAndAllSubExprNegation": false,
    "LogicalAndNegation": false,
    "LogicalAndSingleSubExprNegation": false,
    "LogicalOrAllSubExprNegation": false,
    "LogicalOrNegation": false,
    "LogicalOrSingleSubExprNegation": false,

    // ── Per-method ignores (equivalent mutants) ──────────────────────

    "TrueValue": {
      "ignoreSourceCodeByRegex": [
        ".*match\\s*\\(true\\).*",
      ],
    },
    // Lexer position-tracking arithmetic ($pos/$col) — shifting
    // positions never changes which tokens are emitted.
    "IncrementInteger": {
      "ignore": [
        "Superscript\\Axiom\\Dsl\\Lexer\\Lexer::tokenize",
        "Superscript\\Axiom\\Dsl\\Lexer\\Lexer::matchOperator",
        "Superscript\\Axiom\\Dsl\\Parser\\Parser::parseInfixExpression",
        "Superscript\\Axiom\\Dsl\\PrettyPrinter\\PrettyPrinter::printExpression",
        "Superscript\\Axiom\\Dsl\\PrettyPrinter\\PrettyPrinter::printInfixExpression",
        "Superscript\\Axiom\\Dsl\\PrettyPrinter\\PrettyPrinter::printUnaryExpression",
      ],
    },
    "DecrementInteger": {
      "ignore": [
        "Superscript\\Axiom\\Dsl\\Lexer\\Lexer::tokenize",
        "Superscript\\Axiom\\Dsl\\Parser\\Parser::parseInfixExpression",
        "Superscript\\Axiom\\Dsl\\PrettyPrinter\\PrettyPrinter::printExpression",
        "Superscript\\Axiom\\Dsl\\PrettyPrinter\\PrettyPrinter::printInfixExpression",
        "Superscript\\Axiom\\Dsl\\PrettyPrinter\\PrettyPrinter::printUnaryExpression",
      ],
    },
    "Increment": {
      "ignore": [
        "Superscript\\Axiom\\Dsl\\Lexer\\Lexer::tokenize",
      ],
    },
    "Assignment": {
      "ignore": [
        "Superscript\\Axiom\\Dsl\\Lexer\\Lexer::tokenize",
      ],
    },
    "PlusEqual": {
      "ignore": [
        "Superscript\\Axiom\\Dsl\\Lexer\\Lexer::tokenize",
      ],
    },
    // Boundary condition flips on lookahead guards and precedence
    // comparisons that never fire at the exact boundary value.
    "LessThan": {
      "ignore": [
        "Superscript\\Axiom\\Dsl\\Lexer\\Lexer::tokenize",
        "Superscript\\Axiom\\Dsl\\Parser\\Parser::parseInfixExpression",
        "Superscript\\Axiom\\Dsl\\PrettyPrinter\\PrettyPrinter::printUnaryExpression",
      ],
    },
    "GreaterThanOrEqualTo": {
      "ignore": [
        "Superscript\\Axiom\\Dsl\\Lexer\\Lexer::tokenize",
      ],
    },
    "Continue_": {
      "ignore": [
        "Superscript\\Axiom\\Dsl\\Lexer\\Lexer::tokenize",
      ],
    },
    "Plus": {
      "ignore": [
        "Superscript\\Axiom\\Dsl\\Lexer\\Lexer::tokenize",
        "Superscript\\Axiom\\Dsl\\Lexer\\Lexer::matchOperator",
        "Superscript\\Axiom\\Dsl\\Parser\\Parser::parseInfixExpression",
        "Superscript\\Axiom\\Dsl\\PrettyPrinter\\PrettyPrinter::printInfixExpression",
        "Superscript\\Axiom\\Dsl\\PrettyPrinter\\PrettyPrinter::printUnaryExpression",
      ],
    },
    "LogicalAnd": {
      "ignore": [
        "Superscript\\Axiom\\Dsl\\Lexer\\Lexer::tokenize",
        "Superscript\\Axiom\\Dsl\\Parser\\Parser::parseInfixExpression",
      ],
    },
    // break vs continue at end of while(comma) loop — loop condition
    // is false either way, making these equivalent.
    "Break_": {
      "ignore": [
        "Superscript\\Axiom\\Dsl\\Parser\\Parser::parseListLiteral",
        "Superscript\\Axiom\\Dsl\\Parser\\Parser::parseDictLiteral",
      ],
    },
    // Compiler: single-path conditions that can't be exercised differently.
    "InstanceOf_": {
      "ignore": [
        "Superscript\\Axiom\\Dsl\\Compiler\\Compiler::compileNode",
      ],
    },
    "UnwrapArrayMap": {
      "ignore": [
        "Superscript\\Axiom\\Dsl\\Compiler\\Compiler::applyTypeCoercion",
      ],
    },
    "CastString": {
      "ignore": [
        "Superscript\\Axiom\\Dsl\\Compiler\\Compiler::compileDict",
      ],
    },
    // Parser: complex boolean conditions and safe-navigation that produce
    // equivalent results given the token combinations that actually occur.
    "NullSafePropertyCall": {
      "ignore": [
        "Superscript\\Axiom\\Dsl\\Parser\\Parser::parseInfixExpression",
      ],
    },
    "LogicalOr": {
      "ignore": [
        "Superscript\\Axiom\\Dsl\\Parser\\Parser::parseInfixExpression",
      ],
    },
    "UnwrapSubstr": {
      "ignore": [
        "Superscript\\Axiom\\Dsl\\Parser\\Parser::parseNumberLiteral",
      ],
    },
    // AxiomDsl::fromPlugins: FunctionRegistry is populated for Phase 2
    // forward compat; literal extensions have no plugins in default config.
    "MethodCallRemoval": {
      "ignore": [
        "Superscript\\Axiom\\Dsl\\AxiomDsl::fromPlugins",
      ],
    },
    "FunctionCallRemoval": {
      "ignore": [
        "Superscript\\Axiom\\Dsl\\AxiomDsl::fromPlugins",
      ],
    },
    // PrettyPrinter: precedence fallback `: 0` branch never fires since
    // we only print known operators; extension loop is empty with CoreDslPlugin.
    "NotIdentical": {
      "ignore": [
        "Superscript\\Axiom\\Dsl\\PrettyPrinter\\PrettyPrinter::printUnaryExpression",
      ],
    },
    "Ternary": {
      "ignore": [
        "Superscript\\Axiom\\Dsl\\PrettyPrinter\\PrettyPrinter::printUnaryExpression",
      ],
    },
    "Foreach_": {
      "ignore": [
        "Superscript\\Axiom\\Dsl\\PrettyPrinter\\PrettyPrinter::printExpression",
      ],
    },
    "IfNegation": {
      "ignore": [
        "Superscript\\Axiom\\Dsl\\PrettyPrinter\\PrettyPrinter::printExpression",
      ],
    },
  },
  "logs": {
    "text": "build/infection.log",
  }
}
