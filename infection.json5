{
  "$schema": "vendor/infection/infection/resources/schema.json",
  "source": {
    "directories": [
      "src"
    ],
    "excludes": [
      "Testing"
    ]
  },
  "timeout": 10,
  "minCoveredMsi": 90,
  "minMsi": 90,
  "mutators": {
    "@default": true,
    "TrueValue": {
      "ignoreSourceCodeByRegex": [
        ".*match\\s*\\(true\\).*",
      ],
    },
    // Position-tracking arithmetic in the lexer produces equivalent mutants —
    // mutating $pos++ or $col += 2 shifts column numbers but never changes
    // which tokens are produced, so these can never be killed.
    "IncrementInteger": {
      "ignore": [
        "Superscript\\Axiom\\Dsl\\Lexer\\Lexer::tokenize",
      ],
    },
    "DecrementInteger": {
      "ignore": [
        "Superscript\\Axiom\\Dsl\\Lexer\\Lexer::tokenize",
      ],
    },
    "Increment": {
      "ignore": [
        "Superscript\\Axiom\\Dsl\\Lexer\\Lexer::tokenize",
      ],
    },
    "Assignment": {
      "ignore": [
        "Superscript\\Axiom\\Dsl\\Lexer\\Lexer::tokenize",
      ],
    },
    "PlusEqual": {
      "ignore": [
        "Superscript\\Axiom\\Dsl\\Lexer\\Lexer::tokenize",
      ],
    },
    "Plus": {
      "ignore": [
        "Superscript\\Axiom\\Dsl\\Lexer\\Lexer::tokenize",
      ],
    },
  },
  "logs": {
    "text": "build/infection.log",
  }
}